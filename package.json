{
  "name": "ifc-3d-viewer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./scripts/build-data.js && node ./node_modules/vite/bin/vite.js build && node ./scripts/prepare-deploy.js",
    "build-data": "node ./scripts/build-data.js",
    "prepare-deploy": "node ./scripts/prepare-deploy.js",
    "sync-project-data": "node ./scripts/sync-project-data.js",
    "start": "node ./scripts/serve-production.js",
    "serve": "node ./scripts/serve-production.js",
    "deploy": "npm run build",
    "preview": "node ./node_modules/vite/bin/vite.js preview"
  },
  "dependencies": {
    "three": "^0.135.0",
    "web-ifc-viewer": "^1.0.218"
  },
  "devDependencies": {
    "vite": "^8.0.16"
  }
}
