{
  "meta": {
    "title": "Simpson Strong-Tie Hanger Selector — Parameter Reference",
    "appUrl": "https://app.strongtie.com/hs",
    "apiBase": "https://api.strongtie.com/gws",
    "apiEndpoint": "POST /hanger-selector/hangers",
    "sources": [
      "https://docs.strongtie.com/help-center/hanger-selector/differences-between-cs-and-hs",
      "https://docs.strongtie.com/home-page/connector-selector/apis/openapi/joist/paths/~1api~1Hangers/post",
      "https://docs.strongtie.com/home-page/connector-selector/apis/openapi/trussmulti-truss/paths/~1api~1trusshangers/post"
    ],
    "notes": [
      "All three UI connection types use one API endpoint; flushOption distinguishes joist vs truss.",
      "Loads are ASD (Allowable Stress Design) in pounds unless noted.",
      "Download/uplift duration factors map to designInformations.downloadDurationType and upliftLoadDurationType."
    ]
  },
  "connectionTypes": [
    {
      "id": "joist_flush_top",
      "uiLabel": "Joist (Flush Top)",
      "description": "Carried joist hangs from bottom of header/beam with top of joist flush to header bottom.",
      "flushOption": "TOP",
      "carriedMemberCount": { "min": 1, "max": 1, "label": "Single joist" },
      "hangerOptions": "required",
      "carryingMemberExtraFields": ["topChord"],
      "diagram": "Header (carrying) above → hanger wraps joist bottom (carried)"
    },
    {
      "id": "truss_flush_bottom",
      "uiLabel": "Truss (Flush Bottom)",
      "description": "Single truss hung from girder with bottom chord flush to girder support line.",
      "flushOption": "BOTTOM",
      "carriedMemberCount": { "min": 1, "max": 1, "label": "Single truss in carriedMembers[0]" },
      "hangerOptions": null,
      "carryingMemberExtraFields": ["kingHeight", "kingWidth", "topChordPly"],
      "diagram": "Girder (carrying) → one truss (carried) at bottom flush"
    },
    {
      "id": "multi_truss_flush_bottom",
      "uiLabel": "Multi-Truss (Flush Bottom)",
      "description": "Up to three trusses on one girder hanger (left, center, right positions).",
      "flushOption": "BOTTOM",
      "carriedMemberCount": { "min": 2, "max": 3, "label": "2–3 entries in carriedMembers array" },
      "hangerOptions": null,
      "carryingMemberExtraFields": ["kingHeight", "kingWidth", "topChordPly"],
      "nullSlotRules": [
        { "configuration": "Left + Center", "nullIndex": 2, "note": "carriedMembers[2] = null" },
        { "configuration": "Left + Right", "nullIndex": 1, "note": "carriedMembers[1] = null" },
        { "configuration": "Center + Right", "nullIndex": 0, "note": "carriedMembers[0] = null" }
      ],
      "diagram": "Girder → up to 3 truss seats (use null slot for unused position)"
    }
  ],
  "uiSections": [
    {
      "id": "connection_type",
      "uiLabel": "Connection Type",
      "appliesTo": ["joist_flush_top", "truss_flush_bottom", "multi_truss_flush_bottom"],
      "fields": [
        {
          "uiLabel": "Connection Type",
          "apiField": "flushOption",
          "type": "enum",
          "enumKey": "flushOption",
          "required": true
        }
      ]
    },
    {
      "id": "job_settings",
      "uiLabel": "Job Settings",
      "appliesTo": ["joist_flush_top", "truss_flush_bottom", "multi_truss_flush_bottom"],
      "fields": [
        { "uiLabel": "Hanger Type", "apiField": "style", "type": "enum", "enumKey": "style", "uiHint": "All Types / Face / Top Flange" },
        { "uiLabel": "Fastener Type", "apiField": "fastenerType", "type": "enum", "enumKey": "fastenerType" },
        { "uiLabel": "Download Duration", "apiField": "designInformations.downloadDurationType", "type": "integer", "uiHint": "e.g. Floor = 100" },
        { "uiLabel": "Uplift Duration", "apiField": "designInformations.upliftLoadDurationType", "type": "integer", "uiHint": "e.g. Quake/Wind = 160" },
        { "uiLabel": "Building Code", "apiField": "buildingCode", "type": "enum", "enumKey": "buildingCode" },
        { "uiLabel": "Concealed Flange", "apiField": "concealed", "type": "enum", "enumKey": "concealed" },
        { "uiLabel": "Ledger Connection", "apiField": "ledger", "type": "enum", "enumKey": "ledger" },
        { "uiLabel": "ANSI TPI", "apiField": "ansitpi", "type": "enum", "enumKey": "ansitpi", "appliesTo": ["truss_flush_bottom", "multi_truss_flush_bottom"] },
        { "uiLabel": "Sort Results By", "apiField": "sort", "type": "enum", "enumKey": "sort" },
        { "uiLabel": "Job ID", "apiField": null, "type": "string", "uiHint": "UI-only label for job list export" },
        { "uiLabel": "Quantity", "apiField": null, "type": "integer", "uiHint": "UI-only quantity for job list / CSV" }
      ]
    },
    {
      "id": "filters",
      "uiLabel": "Hanger Filters (optional)",
      "appliesTo": ["joist_flush_top", "truss_flush_bottom", "multi_truss_flush_bottom"],
      "fields": [
        { "uiLabel": "Series Filter", "apiField": "filters.series", "type": "string" },
        { "uiLabel": "Model Filter", "apiField": "filters.model", "type": "string" },
        { "uiLabel": "Width Filter", "apiField": "filters.width", "type": "number", "unit": "in" },
        { "uiLabel": "Depth Filter", "apiField": "filters.depth", "type": "number", "unit": "in" },
        { "uiLabel": "Web Stiffeners", "apiField": "filters.webStiffeners", "type": "enum", "enumKey": "webStiffeners" }
      ]
    },
    {
      "id": "carrying_member",
      "uiLabel": "Header / Girder (Carrying Member)",
      "apiField": "carryingMember",
      "legacyApiField": "headerMember | girder",
      "appliesTo": ["joist_flush_top", "truss_flush_bottom", "multi_truss_flush_bottom"],
      "fields": [
        { "uiLabel": "Member Type", "apiField": "carryingMember.material", "type": "enum", "enumKey": "material", "uiHint": "Solid Sawn, Truss, I-Joist, etc." },
        { "uiLabel": "Lumber Species", "apiField": "carryingMember.material", "type": "enum", "enumKey": "material" },
        { "uiLabel": "Width", "apiField": "carryingMember.width", "type": "number", "unit": "in", "uiHint": "e.g. 1.5 for 2x" },
        { "uiLabel": "Depth", "apiField": "carryingMember.depth", "type": "number", "unit": "in", "uiHint": "actual depth, e.g. 5.5 for 2x6" },
        { "uiLabel": "Number of Plies", "apiField": "carryingMember.ply", "type": "integer" },
        { "uiLabel": "Top Chord Ply", "apiField": "carryingMember.topChordPly", "type": "integer", "appliesTo": ["truss_flush_bottom", "multi_truss_flush_bottom"] },
        { "uiLabel": "Top Chord", "apiField": "carryingMember.topChord", "type": "integer", "appliesTo": ["joist_flush_top"], "uiHint": "4x2 floor truss use case" },
        { "uiLabel": "King Post Height", "apiField": "carryingMember.kingHeight", "type": "number", "unit": "in", "appliesTo": ["truss_flush_bottom", "multi_truss_flush_bottom"] },
        { "uiLabel": "King Post Width", "apiField": "carryingMember.kingWidth", "type": "number", "unit": "in", "appliesTo": ["truss_flush_bottom", "multi_truss_flush_bottom"] },
        { "uiLabel": "Member ID", "apiField": null, "type": "string", "uiHint": "UI label only" },
        { "uiLabel": "Lumber Finish", "apiField": null, "type": "string", "uiHint": "Rough Sawn / S4S — UI only in HS app" }
      ]
    },
    {
      "id": "carried_member",
      "uiLabel": "Joist / Truss (Carried Member)",
      "apiField": "carriedMembers[]",
      "legacyApiField": "joistMember | truss[]",
      "appliesTo": ["joist_flush_top", "truss_flush_bottom", "multi_truss_flush_bottom"],
      "fields": [
        { "uiLabel": "Member Type", "apiField": "carriedMembers[].material", "type": "enum", "enumKey": "material" },
        { "uiLabel": "Lumber Species", "apiField": "carriedMembers[].material", "type": "enum", "enumKey": "material" },
        { "uiLabel": "Width", "apiField": "carriedMembers[].width", "type": "number", "unit": "in" },
        { "uiLabel": "Depth", "apiField": "carriedMembers[].depth", "type": "number", "unit": "in" },
        { "uiLabel": "Number of Plies", "apiField": "carriedMembers[].ply", "type": "integer" },
        { "uiLabel": "Download (ASD)", "apiField": "carriedMembers[].loads.load", "type": "integer", "unit": "lb" },
        { "uiLabel": "Uplift (ASD)", "apiField": "carriedMembers[].loads.uplift", "type": "integer", "unit": "lb" },
        { "uiLabel": "Member ID", "apiField": null, "type": "string", "uiHint": "UI label only" },
        { "uiLabel": "Lumber Finish", "apiField": null, "type": "string", "uiHint": "UI only" }
      ]
    },
    {
      "id": "slope_skew",
      "uiLabel": "Slope & Skew (per carried member)",
      "apiField": "carriedMembers[].angle",
      "appliesTo": ["joist_flush_top", "truss_flush_bottom", "multi_truss_flush_bottom"],
      "fields": [
        { "uiLabel": "Skew (Degrees)", "apiField": "carriedMembers[].angle.skewAngle", "type": "number", "unit": "deg" },
        { "uiLabel": "Skew Direction", "apiField": "carriedMembers[].angle.skewType", "type": "enum", "enumKey": "skewType", "uiHint": "Left / Right" },
        { "uiLabel": "Slope (Degrees)", "apiField": "carriedMembers[].angle.slopeAngle", "type": "number", "unit": "deg" },
        { "uiLabel": "Slope Direction", "apiField": "carriedMembers[].angle.slopeType", "type": "enum", "enumKey": "slopeType", "uiHint": "Up / Down" }
      ]
    },
    {
      "id": "hanger_options",
      "uiLabel": "Hanger Options (Top Flange)",
      "apiField": "hangerOptions.topFlangeOptions",
      "appliesTo": ["joist_flush_top"],
      "fields": [
        { "uiLabel": "Top Flange Bend", "apiField": "hangerOptions.topFlangeOptions.topFlangeOpenClosedType", "type": "enum", "enumKey": "topFlangeOpenClosedType", "uiHint": "Closed / Open" },
        { "uiLabel": "Top Flange Bend Angle", "apiField": "hangerOptions.topFlangeOptions.topFlangeOpenClosedAngle", "type": "number", "unit": "deg" },
        { "uiLabel": "Top Flange Slope", "apiField": "hangerOptions.topFlangeOptions.topFlangeSlopedDownType", "type": "enum", "enumKey": "topFlangeSlopedDownType", "uiHint": "Down Left / Down Right" },
        { "uiLabel": "Top Flange Slope Angle", "apiField": "hangerOptions.topFlangeOptions.topFlangeSlopedDownAngle", "type": "number", "unit": "deg" },
        { "uiLabel": "Offset Direction", "apiField": "hangerOptions.topFlangeOptions.topFlangeOffset", "type": "enum", "enumKey": "topFlangeOffset", "uiHint": "Centered / High-Low-Center flush" }
      ]
    },
    {
      "id": "output",
      "uiLabel": "Output",
      "appliesTo": ["joist_flush_top", "truss_flush_bottom", "multi_truss_flush_bottom"],
      "fields": [
        { "uiLabel": "Model", "apiField": "response.models[].model", "type": "string" },
        { "uiLabel": "Installed Cost", "apiField": "response.models[].installedCost", "type": "number" },
        { "uiLabel": "Download Capacity", "apiField": "response.models[].download", "type": "integer", "unit": "lb" },
        { "uiLabel": "Uplift Capacity", "apiField": "response.models[].uplift", "type": "integer", "unit": "lb" },
        { "uiLabel": "TF / Face / Joist Fasteners", "apiField": "response.models[].fasteners", "type": "object" },
        { "uiLabel": "3D Viewer Layers", "apiField": null, "type": "ui", "uiHint": "Carrying, Carried, Hanger visibility toggles" },
        { "uiLabel": "Job List / CSV", "apiField": null, "type": "export", "uiHint": "Add to job list, download CSV, fastener totals" }
      ]
    }
  ],
